#!/usr/bin/env bash
#
# Pre-commit hook: lint, format check, and secret scan.
# Install: git config core.hooksPath .githooks
# Or:      cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#

set -euo pipefail

# ── Lint ──────────────────────────────────────────────────────────────────
echo "Running lint..."
npm run lint || { echo "Lint failed. Fix errors before committing."; exit 1; }

# ── Format check ─────────────────────────────────────────────────────────
echo "Running format check..."
npm run format:check || { echo "Format check failed. Run 'npx prettier --write .' to fix."; exit 1; }

# ── Secret scan ──────────────────────────────────────────────────────────

# Patterns that indicate leaked secrets (ERE syntax — works on macOS and Linux)
SECRET_PATTERNS=(
  # AWS access key IDs
  'AKIA[0-9A-Z]{16}'
  # Private keys (PEM)
  '-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----'
  # GitHub tokens
  'gh[pousr]_[A-Za-z0-9_]{36,}'
  # npm tokens
  'npm_[A-Za-z0-9]{36}'
  # Slack tokens
  'xox[bporas]-[0-9a-zA-Z-]+'
  # Google API keys
  'AIza[0-9A-Za-z_-]{35}'
  # Google OAuth client secrets
  'GOCSPX-[A-Za-z0-9_-]{28}'
  # Azure/Microsoft tokens
  'eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}'
  # Generic high-entropy secret assignments (key="...." or secret: "....")
  '(SECRET|PASSWORD|PASSWD|TOKEN|API_KEY|APIKEY|AUTH_TOKEN|ACCESS_KEY|PRIVATE_KEY)[_[:space:]]*[:=][[:space:]]*["\x27][^\x27"]{8,}'
  # Bearer tokens
  '[Bb][Ee][Aa][Rr][Ee][Rr][[:space:]]+[A-Za-z0-9._-]{20,}'
)

# Files to skip (binary, lockfiles, test fixtures)
SKIP_PATTERN='\.(lock|png|jpg|gif|ico|woff2?|ttf|jar|class|interp|tokens|min\.js)$|package-lock\.json$|node_modules/|dist/'

# Load per-line allowlist from .secret-scan-ignore (one pattern per line, # comments)
ALLOWLIST=()
if [ -f ".secret-scan-ignore" ]; then
  while IFS= read -r line; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue  # skip comments
    [[ -z "$line" ]] && continue                  # skip blank lines
    ALLOWLIST+=("$line")
  done < ".secret-scan-ignore"
fi

is_allowed() {
  local match_line="$1"
  for allowed in "${ALLOWLIST[@]}"; do
    if echo "$match_line" | grep -qF "$allowed"; then
      return 0
    fi
  done
  return 1
}

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

FOUND=0

for pattern in "${SECRET_PATTERNS[@]}"; do
  # Search staged content (not working tree) for secret patterns
  MATCHES=$(echo "$STAGED_FILES" | grep -Ev "$SKIP_PATTERN" | while read -r file; do
    git show ":$file" 2>/dev/null | grep -Eni -e "$pattern" | while read -r line; do
      match_line="$file:$line"
      if ! is_allowed "$match_line"; then
        echo "  $match_line"
      fi
    done
  done || true)

  if [ -n "$MATCHES" ]; then
    if [ "$FOUND" -eq 0 ]; then
      echo "ERROR: Possible secrets detected in staged files:"
      echo ""
    fi
    FOUND=1
    echo "$MATCHES"
  fi
done

if [ "$FOUND" -ne 0 ]; then
  echo ""
  echo "If these are false positives, commit with: git commit --no-verify"
  echo "Otherwise, remove the secrets and try again."
  exit 1
fi
