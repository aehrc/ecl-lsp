-// Copy shared TextMate grammar into plugin resources at build time
+// Copy shared TextMate grammar into plugin resources (for reference) at build time
 tasks.processResources {
     from("../../shared/syntaxes/ecl.tmLanguage.json") {
         into("textmate/ecl/Syntaxes")
     }
 }
+
+// --- Bundle the ECL language server into the plugin ---
+
+val serverDir = file("../../server")
+val serverBuildDir = layout.buildDirectory.dir("ecl-server")
+
+val bundleServer by tasks.registering(Sync::class) {
+    description = "Bundle the ECL language server dist into the plugin"
+
+    from(serverDir.resolve("dist")) {
+        exclude("test/**")
+    }
+    into(serverBuildDir.map { it.dir("dist") })
+}
+
+val installServerDeps by tasks.registering(Exec::class) {
+    description = "Install production-only Node.js dependencies for the bundled server"
+    dependsOn(bundleServer)
+
+    inputs.file(serverDir.resolve("package.json"))
+    outputs.dir(serverBuildDir.map { it.dir("node_modules") })
+
+    doFirst {
+        copy {
+            from(serverDir.resolve("package.json"))
+            into(serverBuildDir)
+        }
+    }
+
+    workingDir = serverBuildDir.get().asFile
+    commandLine("npm", "install", "--production", "--no-optional", "--ignore-scripts")
+
+    doLast {
+        // Clean up lock file (package.json is needed at runtime by fhir-service.js)
+        serverBuildDir.get().asFile.resolve("package-lock.json").delete()
+    }
+}
+
+// Hook into prepareSandbox to copy bundled server and TextMate grammar into plugin directory
+tasks.named<Sync>("prepareSandbox") {
+    dependsOn(installServerDeps)
+    from(serverBuildDir) {
+        into("${project.name}/ecl-server")
+    }
+    from("../../shared/syntaxes/ecl.tmLanguage.json") {
+        into("${project.name}/textmate/ecl/Syntaxes")
+    }
+    from("src/main/resources/textmate/ecl/package.json") {
+        into("${project.name}/textmate/ecl")
+    }
+}
