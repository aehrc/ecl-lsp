+            val date = match.groupValues[2]
+
+            editionMap.getOrPut(moduleId) { mutableListOf() }
+                .add(SnomedVersion(uri = version, date = date))
+        }
+
+        return editionMap.map { (moduleId, versions) ->
+            versions.sortByDescending { it.date }
+            SnomedEdition(moduleId = moduleId, versions = versions)
+        }
+    }
