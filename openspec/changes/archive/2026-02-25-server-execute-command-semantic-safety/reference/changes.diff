+describe('Partial AST Safety (syntax errors)', () => {
+  it('should not crash on duplicate operator expression', async () => {
+    const svc = new SemanticMockService();
+    const result = parseECL('< 404684003 AND AND < 19829001');
+    // This expression has syntax errors — AST may be partial or null
+    if (result.ast) {
+      const diags = await validateSemantics(result.ast, '< 404684003 AND AND < 19829001', svc);
+      assert.ok(Array.isArray(diags));
+    }
+  });
+
+  it('should not crash on incomplete expression', async () => {
+    const svc = new SemanticMockService();
+    const result = parseECL('< 404684003 AND');
+    if (result.ast) {
+      const diags = await validateSemantics(result.ast, '< 404684003 AND', svc);
+      assert.ok(Array.isArray(diags));
+    }
+  });
+
+  it('should not crash on missing operator expression', async () => {
+    const svc = new SemanticMockService();
+    const result = parseECL('< 404684003 < 19829001');
+    if (result.ast) {
+      const diags = await validateSemantics(result.ast, '< 404684003 < 19829001', svc);
+      assert.ok(Array.isArray(diags));
+    }
+  });
+
+  it('should not crash on empty expression', async () => {
+    const svc = new SemanticMockService();
+    const result = parseECL('');
+    if (result.ast) {
+      const diags = await validateSemantics(result.ast, '', svc);
+      assert.ok(Array.isArray(diags));
+    }
+  });
+
+  it('should not crash on incomplete refinement', async () => {
+    const svc = new SemanticMockService();
+    const result = parseECL('< 404684003 : 363698007 =');
+    if (result.ast) {
+      const diags = await validateSemantics(result.ast, '< 404684003 : 363698007 =', svc);
+      assert.ok(Array.isArray(diags));
+    }
+  });
+
+  it('should not crash on nested incomplete expression', async () => {
+    const svc = new SemanticMockService();
+    const result = parseECL('(< 404684003 AND) OR < 19829001');
+    if (result.ast) {
+      const diags = await validateSemantics(result.ast, '(< 404684003 AND) OR < 19829001', svc);
+      assert.ok(Array.isArray(diags));
+    }
+  });
+});
