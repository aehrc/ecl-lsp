{
  "name": "@aehrc/ecl-editor-react",
  "version": "1.0.2",
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "author": "Commonwealth Scientific and Industrial Research Organisation (CSIRO)",
  "repository": {
    "type": "git",
    "url": "https://github.com/aehrc/ecl-lsp.git",
    "directory": "packages/ecl-editor-react"
  },
  "homepage": "https://github.com/aehrc/ecl-lsp/tree/main/packages/ecl-editor-react#readme",
  "bugs": {
    "url": "https://github.com/aehrc/ecl-lsp/issues"
  },
  "description": "React component for ECL editing with Monaco",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**",
    "LICENSE"
  ],
  "scripts": {
    "prepack": "node -e \"require('fs').copyFileSync('../../LICENSE','LICENSE')\"",
    "build": "vite build",
    "compile": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@aehrc/ecl-editor-core": "file:../ecl-editor-core"
  },
  "peerDependencies": {
    "@monaco-editor/react": ">=4.6.0",
    "monaco-editor": ">=0.40.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@monaco-editor/react": {
      "optional": false
    }
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@playwright/test": "^1.58.2",
    "@storybook/react-vite": "^9.0.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "jsdom": "^26.1.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "storybook": "^9.0.4",
    "typescript": "^5.3.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vitest": "^3.2.1"
  }
}
