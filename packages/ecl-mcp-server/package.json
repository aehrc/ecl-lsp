{
  "name": "ecl-mcp-server",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "author": "Commonwealth Scientific and Industrial Research Organisation (CSIRO)",
  "repository": {
    "type": "git",
    "url": "https://github.com/aehrc/ecl-lsp.git",
    "directory": "packages/ecl-mcp-server"
  },
  "homepage": "https://github.com/aehrc/ecl-lsp/tree/main/packages/ecl-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/aehrc/ecl-lsp/issues"
  },
  "description": "MCP server for SNOMED CT Expression Constraint Language",
  "main": "dist/server.js",
  "bin": {
    "ecl-mcp-server": "bin/ecl-mcp-server.js"
  },
  "files": [
    "dist/**",
    "!dist/test/",
    "bin/",
    "LICENSE"
  ],
  "scripts": {
    "prepack": "node -e \"require('fs').copyFileSync('../../LICENSE','LICENSE')\"",
    "compile": "tsc -b",
    "watch": "tsc -b --watch",
    "clean": "rimraf dist",
    "test": "npm run compile && node --test dist/test/*.test.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "ecl-core": "file:../ecl-core",
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.6",
    "rimraf": "^5.0.5"
  }
}
